"Software Update" = "Cập nhật phần mềm";
"Version History" = "Lịch sử phiên bản";
"% downloaded" = "% đã tải";
"%@ of %@" = "%1$@ / %2$@";
"%1$@ of %2$@" = "%1$@ / %2$@";

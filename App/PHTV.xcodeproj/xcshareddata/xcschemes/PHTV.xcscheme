               title = "Prune stale test plug-ins"
               scriptText = "APP_BUNDLE=&quot;${TARGET_BUILD_DIR}/${FULL_PRODUCT_NAME}&quot;&#10;if [ -d &quot;${APP_BUNDLE}/Contents/PlugIns&quot; ]; then&#10;  /bin/rm -rf &quot;${APP_BUNDLE}/Contents/PlugIns&quot;&#10;fi">
